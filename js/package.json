{
  "name": "wakewords",
  "version": "0.3.23",
  "description": "Detect wakewords in browsers and Node.js",
  "type": "module",
  "main": "./src/index-node.js",
  "exports": {
    ".": {
      "browser": "./src/index-browser.js",
      "node": "./src/index-node.js",
      "default": "./src/index-browser.js"
    },
    "./browser": "./src/browser.js",
    "./node": "./src/node.js",
    "./model.onnx": "./assets/model.onnx",
    "./labels.json": "./assets/labels.json"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "node ./tests/preprocessing.test.mjs && node ./tests/inference.test.mjs && node ./tests/entrypoints.test.mjs"
  },
  "dependencies": {
    "onnxruntime-node": "^1.24.3",
    "onnxruntime-web": "^1.22.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HashNuke/wakewords.git"
  },
  "author": "Akash Manohar John",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/HashNuke/wakewords/issues"
  },
  "homepage": "https://github.com/HashNuke/wakewords#readme"
}
